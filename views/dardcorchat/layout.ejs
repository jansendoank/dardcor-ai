display: flex; align-items: center; justify-content: center; backdrop-filter: blur(2px); }
.editor-popup { background: #1e1e1e; border: 1px solid #333; border-radius: 8px; width: 300px;
box-shadow: 0 10px 25px rgba(0,0,0,0.5); overflow: hidden; animation: popupIn 0.2s ease-out; }
.editor-popup-header { background: #252526; padding: 10px 15px; font-size: 13px;
font-weight: bold; color: #ccc; border-bottom: 1px solid #333; }
.editor-popup-body { padding: 15px; }
.editor-popup-input { width: 100%; background: #0a0a12;
border: 1px solid #333; color: #fff; padding: 8px; font-size: 13px; border-radius: 4px; outline: none; }
.editor-popup-input:focus { border-color: #a855f7;
}
.editor-popup-footer { padding: 10px 15px; background: #252526; display: flex; justify-content: flex-end; gap: 8px; border-top: 1px solid #333;
}
.editor-popup-btn { padding: 6px 12px; font-size: 12px; border-radius: 4px; cursor: pointer; border: none; font-weight: 500; }
.btn-cancel { background: transparent;
color: #ccc; }
.btn-cancel:hover { background: #333; }
.btn-confirm { background: #581c87; color: white; }
.btn-confirm:hover { background: #6b21a8; }
.context-menu { position: fixed;
background: #252526; border: 1px solid #454545; border-radius: 5px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); z-index: 50000; padding: 4px 0; min-width: 150px;
}
.context-menu-item { padding: 6px 12px; font-size: 12px; color: #cccccc; cursor: pointer; display: flex; align-items: center; gap: 8px;
}
.context-menu-item:hover { background: #094771; color: white; }
.context-menu-item i { width: 14px; text-align: center; }
.context-menu-separator { height: 1px; background: #454545;
margin: 4px 0; }
@media (max-width: 768px) { .editor-sidebar { width: 0; display: none; } .editor-sidebar.active { width: 150px; display: flex;
position: absolute; z-index: 10; height: 100%; } }
.btn-open-in-editor-placeholder { display: none !important; width: 100%; height: 80px; padding: 0; background: #0f0f16;
border: 1px dashed #581c87; color: #a855f7; text-align: center; cursor: pointer; font-family: 'Inter', sans-serif; font-weight: 600; transition: all 0.2s; border-radius: 8px;
flex-direction: column; align-items: center; justify-content: center; gap: 8px; margin: 0; box-sizing: border-box; }
.btn-open-in-editor-placeholder:hover { background: #1a1a24; color: #fff; border-color: #d8b4fe;
box-shadow: 0 0 15px rgba(168, 85, 247, 0.2); }
body.vscode-active .terminal-scroll-area, body.vscode-active .terminal-head { display: none !important;
}
body.vscode-active .btn-open-in-editor-placeholder { display: flex !important; }
</style>
</head>
<body class="flex bg-[#050508] h-full overflow-hidden fixed inset-0">
<div id="mobile-overlay" class="fixed inset-0 bg-black/80 z-[9998] hidden lg:hidden backdrop-blur-sm transition-opacity" onclick="window.toggleSidebar()"></div>

<div id="diagram-overlay" class="fixed inset-0 z-[10000] hidden bg-[#050508]">
<button onclick="window.closePreview()" class="absolute top-2 right-2 z-[10001] text-gray-400 hover:text-white bg-black/50 hover:bg-black/80 w-8 h-8 flex items-center justify-center rounded-full backdrop-blur-sm transition-all border border-white/10 shadow-lg">
<i class="fas fa-times text-sm"></i>
</button>
<iframe id="diagram-frame" class="w-full h-full border-none bg-white"></iframe>
</div>

<aside id="sidebar" class="fixed inset-y-0 left-0 w-72 bg-[#0a0a12] border-r border-white/10 flex flex-col z-[9999] transform -translate-x-full lg:translate-x-0 h-full shadow-2xl safe-pl transition-none">
<div class="h-16 shrink-0 flex items-center px-4 border-b border-white/10 bg-[#0a0a12] relative">
<span class="font-bold text-lg text-purple-400 flex items-center gap-3">
<img src="/logo.png" class="w-7 h-7 rounded-full shadow-lg" alt="Logo"> 
Dardcor <span class="text-white">AI</span>
</span>
<button onclick="window.toggleSidebar()" 
class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white transition-colors p-2">
<i class="fas fa-times text-lg"></i>
</button>
</div>

<div class="flex-1 overflow-y-auto p-2 scrollbar-hide">
<% 
let isNewChatActive = true;
if (conversationList && conversationList.length > 0 && activeConversationId) {
const exists = conversationList.some(c => c.id === activeConversationId);
if (exists) isNewChatActive = false;
} 
%>
<div id="current-new-chat-item" onclick="window.createNewChat()" class="static-new-chat-item group relative flex items-center px-3 py-2.5 rounded-lg cursor-pointer w-full transition-all border border-purple-900 <%= isNewChatActive ? 'bg-[#202336] text-white' : 'bg-white/5 hover:bg-white/10 text-gray-400' %>">
<div class="flex-1 min-w-0 flex items-center">
<i class="fas fa-plus mr-3 text-sm"></i>
<span class="text-xs font-bold uppercase tracking-wider">New Chat</span>
</div>
</div>

<div class="text-[9px] text-gray-500 font-bold uppercase tracking-widest px-3 mb-2 mt-4 text-center">Riwayat</div>
<div class="space-y-[1px] px-1">
<% if (conversationList) { conversationList.forEach(chat => { %>
<div id="chat-item-<%= chat.id %>" onclick="window.loadChat('<%= chat.id %>')" class="chat-item group relative flex items-center px-3 py-2.5 rounded-lg cursor-pointer w-full transition-all <%= chat.id === activeConversationId ? 'bg-[#202336] text-white border-l-2 border-purple-900' : 'text-gray-400 border-l-2 border-transparent hover:bg-white/5' %>">
<div class="flex-1 min-w-0 flex items-center">
<span id="title-<%= 
chat.id %>" class="text-xs truncate"><%= chat.title ? chat.title.substring(0, 25) : 'Percakapan' %></span>
<input type="hidden" id="raw-title-<%= chat.id %>" value="<%= chat.title ? chat.title.replace(/"/g, '&quot;').replace(/'/g, '&#39;') : '' %>">
</div>
<button onclick="event.stopPropagation();
window.toggleMenu(event, 'menu-<%= chat.id %>')" class="options-btn absolute right-2 z-20 w-6 h-6 flex items-center justify-center text-gray-400 hover:text-white transition-opacity bg-transparent outline-none focus:outline-none <%= chat.id === activeConversationId ?
'opacity-100' : 'opacity-0 group-hover:opacity-100' %>">
<i class="fas fa-ellipsis-v text-[10px]"></i>
</button>

<div id="menu-<%= chat.id %>" class="hidden absolute right-2 top-8 w-32 bg-[#2a2d3d] border border-gray-600 rounded-lg shadow-xl z-30 py-1" onclick="event.stopPropagation()">
<button onclick="window.openRenameModal('<%= chat.id %>')" class="w-full text-left px-3 py-2 text-xs hover:bg-white/10 text-gray-300 flex gap-2 items-center">
<i class="fas fa-edit"></i> Edit
</button>

<button onclick="window.openDeleteModal('<%= chat.id %>')" class="w-full text-left px-3 py-2 text-xs text-red-400 hover:bg-white/10 flex gap-2 items-center">
<i class="fas fa-trash"></i> Hapus
</button>
</div>
</div>
<% }) } %>
</div>
</div>

<div class="p-4 border-t border-white/10 bg-[#08080c] flex justify-between items-center">
<a href="/dardcorchat/profile" class="flex items-center gap-3">
<img src="<%= user.profile_image ||
('https://ui-avatars.com/api/?name=' + encodeURIComponent(user.username || 'User')) %>" class="w-8 h-8 rounded-full bg-gray-700 object-cover" alt="Profile">
<div class="text-xs font-bold text-white truncate w-24"><%= user.username %></div>
</a>
<a href="/dardcor-logout" class="text-gray-500 hover:text-red-400">
<i class="fas fa-power-off"></i>
</a>
</div>
</aside>

<main id="main-content" class="absolute inset-0 right-0 h-full bg-[#050508] lg:left-72 w-full lg:w-[calc(100%-18rem)] flex overflow-hidden">
<div id="chat-wrapper">
<div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
<div class="star w-0.5 h-0.5 top-10 left-20 animate-star" style="animation-delay: 0s;"></div>
<div class="star w-1 h-1 top-1/4 right-1/4 animate-star" style="animation-delay: 1s;"></div>
<div class="star w-0.5 h-0.5 bottom-1/3 left-1/3 animate-star" style="animation-delay: 2s;"></div>
<div class="star w-1 h-1 top-20 right-10 animate-star" style="animation-delay: 1.5s;"></div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-purple-900/10 rounded-full blur-[80px] md:blur-[100px] pointer-events-none"></div>
</div>

<header class="h-16 shrink-0 flex items-center justify-between px-4 border-b border-purple-900/20 bg-[#050508]/80 backdrop-blur-md z-30 relative">
<div class="flex 
items-center">
<button onclick="window.toggleSidebar()" class="text-gray-400 hover:text-white transition-colors mr-3 flex items-center justify-center w-10 h-10 lg:hidden z-50">
<i class="fas fa-bars text-xl"></i>
</button>
<button onclick="window.toggleSidebar()" class="text-gray-400 hover:text-white transition-colors mr-3 hidden lg:flex items-center justify-center">
<i class="fas fa-bars text-lg"></i>
</button>
</div>
<div id="navbar-alert" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 px-4 py-1.5 bg-[#1c1c2e] border border-purple-900/30 rounded-full shadow-lg flex items-center gap-2 transition-all duration-300 opacity-0 pointer-events-none transform scale-90 z-[10000]">
<i id="navbar-alert-icon" class="fas fa-info-circle text-purple-400 text-xs"></i>
<span id="navbar-alert-text" class="text-xs font-bold text-gray-200 whitespace-nowrap">Notification</span>
</div>

<div class="flex items-center gap-2 ml-auto">
<button id="refresh-chat-btn" class="w-9 h-9 flex items-center justify-center rounded-lg border border-purple-900 bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white transition-all">
<i id="refresh-icon" class="fas fa-sync-alt text-xs"></i>
</button>
</div>
</header>

<div id="chat-container" class="flex-1 w-full overflow-y-auto overflow-x-hidden scrollbar-hide relative px-4 pt-6 z-10">
<div id="message-list" class="w-full max-w-3xl mx-auto flex flex-col gap-6 
pt-4 pb-4">
<%- include(contentPage) %>
</div>
</div>

<div class="flex-none w-full bg-[#050508] z-30" style="padding-bottom: env(safe-area-inset-bottom);">
<%- include('input') %>
</div>
</div>

<div id="editor-wrapper">
<div class="h-10 bg-[#252526] border-b border-[#3e3e42] flex items-center px-4 justify-between shrink-0">
<div class="flex items-center gap-3">
<i class="fas fa-code text-[#007acc] text-sm"></i>
<span class="text-xs text-[#cccccc] font-medium">VS Code Editor</span>
</div>
<button onclick="document.body.classList.remove('vscode-active')" class="text-[#cccccc] hover:text-white w-6 h-6 flex items-center justify-center rounded hover:bg-[#444] transition-colors">
<i class="fas fa-times text-xs"></i>
</button>
</div>
<div id="monaco-editor-root" class="flex-1 w-full h-full bg-[#1e1e1e] relative overflow-hidden">
<div class="absolute inset-0 flex items-center justify-center text-[#555] flex-col gap-2">
<i class="fas fa-code text-4xl mb-2 opacity-50"></i>
<span class="text-sm font-mono">Initializing Editor...</span>
</div>
</div>
</div>
</main>

<div id="delete-modal" class="modal">
<div class="bg-[#1c1c2e] p-6 rounded-xl border border-white/10 text-center w-80 shadow-2xl">
<h3 class="font-bold text-white mb-2">Hapus?</h3>
<div class="flex gap-3">
<button onclick="window.closeModal('delete-modal')" class="flex-1 py-2.5 bg-white/5 rounded text-xs text-gray-300">Batal</button>
<button onclick="window.submitDelete()" class="flex-1 py-2.5 bg-red-600 rounded text-xs text-white">Hapus</button>
</div>
</div>
</div>

<div 
id="rename-modal" class="modal">
<div class="bg-[#1c1c2e] p-6 rounded-xl border border-white/10 text-center w-80 shadow-2xl">
<h3 class="font-bold text-white mb-4">Ubah Nama</h3>
<input id="rename-input" class="w-full bg-black/50 border border-white/10 p-2.5 rounded text-white mb-4 text-xs">
<div class="flex gap-3">
<button onclick="window.closeModal('rename-modal')" class="flex-1 py-2.5 bg-white/5 rounded text-xs">Batal</button>
<button onclick="window.submitRename()" class="flex-1 py-2.5 bg-purple-900 rounded text-xs text-white">Simpan</button>
</div>
</div>
</div>

<script src="/js/notfound1.js?v=<%= Date.now() %>" defer></script>
<script src="/js/notfound2.js?v=<%= Date.now() %>" defer></script>
<script src="/js/notfound3.js?v=<%= Date.now() %>" defer></script>
<script src="/js/notfound4.js?v=<%= Date.now() %>" defer></script>
<script src="/js/notfound5.js?v=<%= Date.now() %>" defer></script>
</body>
</html>
